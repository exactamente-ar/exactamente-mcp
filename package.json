{
  "name": "exactamente-mcp",
  "version": "0.1.0",
  "description": "Read-only xmcp MCP server for Exactamente public academic data",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "xmcp build",
    "build:cf": "xmcp build --cf",
    "dev": "xmcp dev",
    "dev:cf": "xmcp dev --cf",
    "deploy": "npm run build:cf && wrangler deploy",
    "deploy:secret": "wrangler secret put OPENAI_APPS_VERIFICATION_TOKEN",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "start-http": "node dist/http.js",
    "start-stdio": "node dist/stdio.js"
  },
  "dependencies": {
    "xmcp": "^0.6.7",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260530.1",
    "@types/node": "^24.0.0",
    "vitest": "^3.2.4",
    "wrangler": "^4.95.0"
  },
  "main": "./dist/stdio.js",
  "files": [
    "dist"
  ],
  "bin": {
    "exactamente-mcp": "./dist/stdio.js"
  }
}
